@model IEnumerable<Center_Education_Management.Model.Paymentgetway>

@{
    ViewData["Title"] = "Paymentgetway List";
}

<h2>Paymentgetway</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Create New</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Id)</th>
            <th>@Html.DisplayNameFor(m => m.CenterId)</th>
            <th>@Html.DisplayNameFor(m => m.OwnerId)</th>
            <th>@Html.DisplayNameFor(m => m.Provider)</th>
            <th>@Html.DisplayNameFor(m => m.Credentials)</th>
            <th>@Html.DisplayNameFor(m => m.IsActive)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@Html.DisplayFor(m => item.Id)</td>
                <td>@Html.DisplayFor(m => item.CenterId)</td>
                <td>@Html.DisplayFor(m => item.OwnerId)</td>
                <td>@Html.DisplayFor(m => item.Provider)</td>
                <td>@Html.DisplayFor(m => item.Credentials)</td>
                <td>@Html.DisplayFor(m => item.IsActive)</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
