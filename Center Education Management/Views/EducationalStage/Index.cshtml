@model IEnumerable<Center_Education_Management.Models.EducationalStage>

@{
    ViewData["Title"] = "EducationalStage List";
}

<h2>EducationalStage</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Create New</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Id)</th>
            <th>@Html.DisplayNameFor(m => m.Name)</th>
            <th>@Html.DisplayNameFor(m => m.LevelNumber)</th>
            <th>@Html.DisplayNameFor(m => m.DisplayName)</th>
            <th>@Html.DisplayNameFor(m => m.EducationSystem)</th>
            <th>@Html.DisplayNameFor(m => m.IsActive)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@Html.DisplayFor(m => item.Id)</td>
                <td>@Html.DisplayFor(m => item.Name)</td>
                <td>@Html.DisplayFor(m => item.LevelNumber)</td>
                <td>@Html.DisplayFor(m => item.DisplayName)</td>
                <td>@Html.DisplayFor(m => item.EducationSystem)</td>
                <td>@Html.DisplayFor(m => item.IsActive)</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
