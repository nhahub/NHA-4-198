@model Center_Education_Management.Model.Exam

@{
    ViewData["Title"] = "Create Exam";
}

<h2>Create Exam</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="TeacherId" class="form-label"></label>
                        <input asp-for="TeacherId" class="form-control" type="number" />
                        <span asp-validation-for="TeacherId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GroupId" class="form-label"></label>
                        <input asp-for="GroupId" class="form-control" type="number" />
                        <span asp-validation-for="GroupId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SubjectId" class="form-label"></label>
                        <input asp-for="SubjectId" class="form-control" type="number" />
                        <span asp-validation-for="SubjectId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" type="text" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DurationMinutes" class="form-label"></label>
                        <input asp-for="DurationMinutes" class="form-control" type="number" />
                        <span asp-validation-for="DurationMinutes" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TotalPoints" class="form-label"></label>
                        <input asp-for="TotalPoints" class="form-control" type="number" step="any" />
                        <span asp-validation-for="TotalPoints" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="ShuffleQuestions" class="form-check-input" type="checkbox" />
                        <label asp-for="ShuffleQuestions" class="form-label"></label>
                        <span asp-validation-for="ShuffleQuestions" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="ShuffleOptions" class="form-check-input" type="checkbox" />
                        <label asp-for="ShuffleOptions" class="form-label"></label>
                        <span asp-validation-for="ShuffleOptions" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ShowResultsAt" class="form-label"></label>
                        <input asp-for="ShowResultsAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="ShowResultsAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="StartsAt" class="form-label"></label>
                        <input asp-for="StartsAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="StartsAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="EndsAt" class="form-label"></label>
                        <input asp-for="EndsAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="EndsAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="Draft">Draft</option>
                            <option value="Published">Published</option>
                            <option value="Closed">Closed</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
