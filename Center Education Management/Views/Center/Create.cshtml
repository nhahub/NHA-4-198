@model Center_Education_Management.Models.Center

@{
    ViewData["Title"] = "Create Center";
}

<h2>Create Center</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="OwnerId" class="form-label"></label>
                        <input asp-for="OwnerId" class="form-control" type="number" />
                        <span asp-validation-for="OwnerId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" type="text" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label"></label>
                        <input asp-for="Slug" class="form-control" type="text" />
                        <span asp-validation-for="Slug" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LogoUrl" class="form-label"></label>
                        <input asp-for="LogoUrl" class="form-control" type="text" />
                        <span asp-validation-for="LogoUrl" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="City" class="form-label"></label>
                        <input asp-for="City" class="form-control" type="text" />
                        <span asp-validation-for="City" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" type="text" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="PendingVerification">PendingVerification</option>
                            <option value="Active">Active</option>
                            <option value="Suspended">Suspended</option>
                            <option value="Deleted">Deleted</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="VerifiedAt" class="form-label"></label>
                        <input asp-for="VerifiedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="VerifiedAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="VerifiedBy" class="form-label"></label>
                        <input asp-for="VerifiedBy" class="form-control" type="number" />
                        <span asp-validation-for="VerifiedBy" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CreatedAt" class="form-label"></label>
                        <input asp-for="CreatedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="CreatedAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdatedAt" class="form-label"></label>
                        <input asp-for="UpdatedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="UpdatedAt" class="text-danger"></span>
                    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
