@model Center_Education_Management.Model.Payment

@{
    ViewData["Title"] = "Create Payment";
}

<h2>Create Payment</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="StudentId" class="form-label"></label>
                        <input asp-for="StudentId" class="form-control" type="number" />
                        <span asp-validation-for="StudentId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CenterId" class="form-label"></label>
                        <input asp-for="CenterId" class="form-control" type="number" />
                        <span asp-validation-for="CenterId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GroupId" class="form-label"></label>
                        <input asp-for="GroupId" class="form-control" type="number" />
                        <span asp-validation-for="GroupId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label"></label>
                        <input asp-for="Amount" class="form-control" type="number" step="any" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Method" class="form-label"></label>
                        <select asp-for="Method" class="form-select">
                            <option value="Cash">Cash</option>
                            <option value="Fawry">Fawry</option>
                            <option value="Instapay">Instapay</option>
                            <option value="Visa">Visa</option>
                            <option value="VodafoneCash">VodafoneCash</option>
                        </select>
                        <span asp-validation-for="Method" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="Pending">Pending</option>
                            <option value="Completed">Completed</option>
                            <option value="Failed">Failed</option>
                            <option value="Refunded">Refunded</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GatewayRef" class="form-label"></label>
                        <input asp-for="GatewayRef" class="form-control" type="text" />
                        <span asp-validation-for="GatewayRef" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="RecordedBy" class="form-label"></label>
                        <input asp-for="RecordedBy" class="form-control" type="number" />
                        <span asp-validation-for="RecordedBy" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PaidAt" class="form-label"></label>
                        <input asp-for="PaidAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="PaidAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CreatedAt" class="form-label"></label>
                        <input asp-for="CreatedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="CreatedAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PaymentGatewayId" class="form-label"></label>
                        <input asp-for="PaymentGatewayId" class="form-control" type="number" />
                        <span asp-validation-for="PaymentGatewayId" class="text-danger"></span>
                    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
