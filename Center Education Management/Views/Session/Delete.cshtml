@model Center_Education_Management.Models.Session

@{
    ViewData["Title"] = "Delete Session";
}

<h2>Delete Session</h2>

<div class="alert alert-danger">Are you sure you want to delete this item?</div>

<dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Id)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Id)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Title)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Title)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.VideoLink)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.VideoLink)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.GroupId)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.GroupId)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.TeacherId)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.TeacherId)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.ClassroomId)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.ClassroomId)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.StartTime)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.StartTime)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.EndTime)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.EndTime)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Status)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Status)</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
