@model Center_Education_Management.Model.QRToken

@{
    ViewData["Title"] = "Edit QRToken";
}

<h2>Edit QRToken</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="SessionId" class="form-label"></label>
                        <input asp-for="SessionId" class="form-control" type="number" />
                        <span asp-validation-for="SessionId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GeneratedById" class="form-label"></label>
                        <input asp-for="GeneratedById" class="form-control" type="number" />
                        <span asp-validation-for="GeneratedById" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Token" class="form-label"></label>
                        <input asp-for="Token" class="form-control" type="text" />
                        <span asp-validation-for="Token" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GeneratedAt" class="form-label"></label>
                        <input asp-for="GeneratedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="GeneratedAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ExpiresAt" class="form-label"></label>
                        <input asp-for="ExpiresAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="ExpiresAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="Active">Active</option>
                            <option value="Used">Used</option>
                            <option value="Expired">Expired</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
