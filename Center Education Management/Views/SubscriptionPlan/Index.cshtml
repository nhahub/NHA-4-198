@model IEnumerable<Center_Education_Management.Model.SubscriptionPlan>

@{
    ViewData["Title"] = "SubscriptionPlan List";
}

<h2>SubscriptionPlan</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Create New</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Id)</th>
            <th>@Html.DisplayNameFor(m => m.Name)</th>
            <th>@Html.DisplayNameFor(m => m.PriceMonthly)</th>
            <th>@Html.DisplayNameFor(m => m.PriceYearly)</th>
            <th>@Html.DisplayNameFor(m => m.PriceSemester)</th>
            <th>@Html.DisplayNameFor(m => m.MaxStudents)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@Html.DisplayFor(m => item.Id)</td>
                <td>@Html.DisplayFor(m => item.Name)</td>
                <td>@Html.DisplayFor(m => item.PriceMonthly)</td>
                <td>@Html.DisplayFor(m => item.PriceYearly)</td>
                <td>@Html.DisplayFor(m => item.PriceSemester)</td>
                <td>@Html.DisplayFor(m => item.MaxStudents)</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
