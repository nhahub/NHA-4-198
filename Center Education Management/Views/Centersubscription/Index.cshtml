@model IEnumerable<Center_Education_Management.Models.Centersubscription>

@{
    ViewData["Title"] = "Centersubscription List";
}

<h2>Centersubscription</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Create New</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Id)</th>
            <th>@Html.DisplayNameFor(m => m.CenterId)</th>
            <th>@Html.DisplayNameFor(m => m.PlanId)</th>
            <th>@Html.DisplayNameFor(m => m.Status)</th>
            <th>@Html.DisplayNameFor(m => m.BillingCycle)</th>
            <th>@Html.DisplayNameFor(m => m.StartsAt)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@Html.DisplayFor(m => item.Id)</td>
                <td>@Html.DisplayFor(m => item.CenterId)</td>
                <td>@Html.DisplayFor(m => item.PlanId)</td>
                <td>@Html.DisplayFor(m => item.Status)</td>
                <td>@Html.DisplayFor(m => item.BillingCycle)</td>
                <td>@Html.DisplayFor(m => item.StartsAt)</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
