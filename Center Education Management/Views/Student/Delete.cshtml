@model Center_Education_Management.view_models.StudentDetailsVM

@{
    ViewData["Title"] = "Delete Student";
}

<h2>Delete Student</h2>

<div class="alert alert-danger">Are you sure you want to delete this student?</div>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@($"{Model.FirstName} {Model.LastName}".Trim())</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Center</dt>
    <dd class="col-sm-9">@Model.CenterName</dd>

    <dt class="col-sm-3">Stage</dt>
    <dd class="col-sm-9">@Model.StageName</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
