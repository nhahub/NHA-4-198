@model Center_Education_Management.Model.ManualGrade

@{
    ViewData["Title"] = "Create ManualGrade";
}

<h2>Create ManualGrade</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="StudentId" class="form-label"></label>
                        <input asp-for="StudentId" class="form-control" type="number" />
                        <span asp-validation-for="StudentId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="RecordedById" class="form-label"></label>
                        <input asp-for="RecordedById" class="form-control" type="number" />
                        <span asp-validation-for="RecordedById" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GroupId" class="form-label"></label>
                        <input asp-for="GroupId" class="form-control" type="number" />
                        <span asp-validation-for="GroupId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SubjectId" class="form-label"></label>
                        <input asp-for="SubjectId" class="form-control" type="number" />
                        <span asp-validation-for="SubjectId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Points" class="form-label"></label>
                        <input asp-for="Points" class="form-control" type="number" step="any" />
                        <span asp-validation-for="Points" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GradedAt" class="form-label"></label>
                        <input asp-for="GradedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="GradedAt" class="text-danger"></span>
                    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
