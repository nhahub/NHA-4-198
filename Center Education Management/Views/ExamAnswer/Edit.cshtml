@model Center_Education_Management.Model.ExamAnswer

@{
    ViewData["Title"] = "Edit ExamAnswer";
}

<h2>Edit ExamAnswer</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="AttemptId" class="form-label"></label>
                        <input asp-for="AttemptId" class="form-control" type="number" />
                        <span asp-validation-for="AttemptId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ExamQuestionId" class="form-label"></label>
                        <input asp-for="ExamQuestionId" class="form-control" type="number" />
                        <span asp-validation-for="ExamQuestionId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="AnswerText" class="form-label"></label>
                        <input asp-for="AnswerText" class="form-control" type="text" />
                        <span asp-validation-for="AnswerText" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="IsAutoGraded" class="form-check-input" type="checkbox" />
                        <label asp-for="IsAutoGraded" class="form-label"></label>
                        <span asp-validation-for="IsAutoGraded" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="EarnedPoints" class="form-label"></label>
                        <input asp-for="EarnedPoints" class="form-control" type="number" step="any" />
                        <span asp-validation-for="EarnedPoints" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GradedBy" class="form-label"></label>
                        <input asp-for="GradedBy" class="form-control" type="number" />
                        <span asp-validation-for="GradedBy" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GradedAt" class="form-label"></label>
                        <input asp-for="GradedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="GradedAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SavedAt" class="form-label"></label>
                        <input asp-for="SavedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="SavedAt" class="text-danger"></span>
                    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
