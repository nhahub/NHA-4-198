@model IEnumerable<Center_Education_Management.Model.ExamAnswer>

@{
    ViewData["Title"] = "ExamAnswer List";
}

<h2>ExamAnswer</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Create New</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Id)</th>
            <th>@Html.DisplayNameFor(m => m.AttemptId)</th>
            <th>@Html.DisplayNameFor(m => m.ExamQuestionId)</th>
            <th>@Html.DisplayNameFor(m => m.AnswerText)</th>
            <th>@Html.DisplayNameFor(m => m.IsAutoGraded)</th>
            <th>@Html.DisplayNameFor(m => m.EarnedPoints)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@Html.DisplayFor(m => item.Id)</td>
                <td>@Html.DisplayFor(m => item.AttemptId)</td>
                <td>@Html.DisplayFor(m => item.ExamQuestionId)</td>
                <td>@Html.DisplayFor(m => item.AnswerText)</td>
                <td>@Html.DisplayFor(m => item.IsAutoGraded)</td>
                <td>@Html.DisplayFor(m => item.EarnedPoints)</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
