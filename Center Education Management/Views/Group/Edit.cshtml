@model Center_Education_Management.Models.Group

@{
    ViewData["Title"] = "Edit Group";
}

<h2>Edit Group</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" type="text" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="MaxCapacity" class="form-label"></label>
                        <input asp-for="MaxCapacity" class="form-control" type="number" />
                        <span asp-validation-for="MaxCapacity" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" class="form-control" type="number" step="any" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ScheduleJson" class="form-label"></label>
                        <input asp-for="ScheduleJson" class="form-control" type="text" />
                        <span asp-validation-for="ScheduleJson" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CreatedAt" class="form-label"></label>
                        <input asp-for="CreatedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="CreatedAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TeacherId" class="form-label"></label>
                        <input asp-for="TeacherId" class="form-control" type="number" />
                        <span asp-validation-for="TeacherId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SubjectId" class="form-label"></label>
                        <input asp-for="SubjectId" class="form-control" type="number" />
                        <span asp-validation-for="SubjectId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SeasonId" class="form-label"></label>
                        <input asp-for="SeasonId" class="form-control" type="number" />
                        <span asp-validation-for="SeasonId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CenterId" class="form-label"></label>
                        <input asp-for="CenterId" class="form-control" type="number" />
                        <span asp-validation-for="CenterId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ClassroomId" class="form-label"></label>
                        <input asp-for="ClassroomId" class="form-control" type="number" />
                        <span asp-validation-for="ClassroomId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="StageId" class="form-label"></label>
                        <input asp-for="StageId" class="form-control" type="number" />
                        <span asp-validation-for="StageId" class="text-danger"></span>
                    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
