@model Center_Education_Management.Models.QuestionBank

@{
    ViewData["Title"] = "Delete QuestionBank";
}

<h2>Delete QuestionBank</h2>

<div class="alert alert-danger">Are you sure you want to delete this item?</div>

<dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Id)</dt>
