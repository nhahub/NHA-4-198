@model IEnumerable<Center_Education_Management.Models.ExamQuestion>

@{
    ViewData["Title"] = "ExamQuestion List";
}

<h2>ExamQuestion</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Create New</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Id)</th>
            <th>@Html.DisplayNameFor(m => m.ExamId)</th>
            <th>@Html.DisplayNameFor(m => m.QuestionBankId)</th>
            <th>@Html.DisplayNameFor(m => m.BodySnapshot)</th>
            <th>@Html.DisplayNameFor(m => m.OptionsSnapshot)</th>
            <th>@Html.DisplayNameFor(m => m.CorrectAnswer)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
                <td>@Html.DisplayFor(m => item.Id)</td>
                <td>@Html.DisplayFor(m => item.ExamId)</td>
                <td>@Html.DisplayFor(m => item.QuestionBankId)</td>
                <td>@Html.DisplayFor(m => item.BodySnapshot)</td>
                <td>@Html.DisplayFor(m => item.OptionsSnapshot)</td>
                <td>@Html.DisplayFor(m => item.CorrectAnswer)</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
