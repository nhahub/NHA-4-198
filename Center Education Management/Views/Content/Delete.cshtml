@model Center_Education_Management.Model.Content

@{
    ViewData["Title"] = "Delete Content";
}

<h2>Delete Content</h2>

<div class="alert alert-danger">Are you sure you want to delete this item?</div>

<dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Id)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Id)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.TeacherId)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.TeacherId)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.GroupId)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.GroupId)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.SessionId)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.SessionId)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.UploadedByID)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.UploadedByID)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Type)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Type)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Title)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Title)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Url)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Url)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.SizeBytes)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.SizeBytes)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Visibility)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Visibility)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.CreatedAt)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.CreatedAt)</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
