@model Center_Education_Management.Models.CenterOwner

@{
    ViewData["Title"] = "Edit CenterOwner";
}

<h2>Edit CenterOwner</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="NationalID" class="form-label"></label>
                        <input asp-for="NationalID" class="form-control" type="text" />
                        <span asp-validation-for="NationalID" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control" type="text" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control" type="text" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" type="text" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PasswordHash" class="form-label"></label>
                        <input asp-for="PasswordHash" class="form-control" type="text" />
                        <span asp-validation-for="PasswordHash" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" type="text" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="AvatarUrl" class="form-label"></label>
                        <input asp-for="AvatarUrl" class="form-control" type="text" />
                        <span asp-validation-for="AvatarUrl" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-label"></label>
                        <span asp-validation-for="IsActive" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="EmailVerified" class="form-check-input" type="checkbox" />
                        <label asp-for="EmailVerified" class="form-label"></label>
                        <span asp-validation-for="EmailVerified" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Salary" class="form-label"></label>
                        <input asp-for="Salary" class="form-control" type="number" step="any" />
                        <span asp-validation-for="Salary" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LastLoginAt" class="form-label"></label>
                        <input asp-for="LastLoginAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="LastLoginAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CreatedAt" class="form-label"></label>
                        <input asp-for="CreatedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="CreatedAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdatedAt" class="form-label"></label>
                        <input asp-for="UpdatedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="UpdatedAt" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="OwnershipType" class="form-label"></label>
                        <select asp-for="OwnershipType" class="form-select">
                            <option value="Individual">Individual</option>
                            <option value="Organization">Organization</option>
                        </select>
                        <span asp-validation-for="OwnershipType" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SubscriptionStatus" class="form-label"></label>
                        <select asp-for="SubscriptionStatus" class="form-select">
                            <option value="Pending">Pending</option>
                            <option value="Active">Active</option>
                            <option value="Expired">Expired</option>
                            <option value="Suspended">Suspended</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                        <span asp-validation-for="SubscriptionStatus" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DefaultPaymentMethod" class="form-label"></label>
                        <select asp-for="DefaultPaymentMethod" class="form-select">
                            <option value="Cash">Cash</option>
                            <option value="Fawry">Fawry</option>
                            <option value="Instapay">Instapay</option>
                            <option value="Visa">Visa</option>
                            <option value="VodafoneCash">VodafoneCash</option>
                        </select>
                        <span asp-validation-for="DefaultPaymentMethod" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="JoinedAt" class="form-label"></label>
                        <input asp-for="JoinedAt" class="form-control" type="datetime-local" />
                        <span asp-validation-for="JoinedAt" class="text-danger"></span>
                    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
