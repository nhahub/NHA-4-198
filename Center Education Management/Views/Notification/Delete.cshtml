@model Center_Education_Management.Model.Notification

@{
    ViewData["Title"] = "Delete Notification";
}

<h2>Delete Notification</h2>

<div class="alert alert-danger">Are you sure you want to delete this item?</div>

<dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Id)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Id)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.UserId)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.UserId)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Type)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Type)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Title)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Title)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Body)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.Body)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.IsRead)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.IsRead)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.RefType)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.RefType)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.RefId)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.RefId)</dd>
        <dt class="col-sm-3">@Html.DisplayNameFor(m => m.CreatedAt)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.CreatedAt)</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
